{
  "name": "obsidian-knowledge-maintenance",
  "version": "0.2.3",
  "description": "Knowledge Maintenance Engine for Obsidian — auto-classify, tag, link, and maintain your vault with AI",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "knowledge-management",
    "ai",
    "maintenance",
    "organize"
  ],
  "author": "dhwang0803",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.0.0",
    "obsidian": "latest",
    "playwright": "^1.61.1",
    "tslib": "^2.7.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
